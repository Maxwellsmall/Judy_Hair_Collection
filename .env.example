# Vercel Environment Variables
# Copy this to .env.local for local development or add to Vercel project settings

# API URL (change this to your deployed backend URL in production)
VITE_API_URL=http://localhost:5000/api

# For production deployment on Vercel, update to:
# VITE_API_URL=https://your-backend-url.com/api
# Or use ngrok/tunnel for local backend:
# VITE_API_URL=https://your-ngrok-url.ngrok.io/api
